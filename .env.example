# ─── Serveur Node (npm run server / npm run dev:full) : mails formulaires via Resend ───
# Ne préfixez pas ces valeurs par VITE_ : la clé reste secrète sur le serveur uniquement.
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=SporFormation <onboarding@resend.dev>
DIRECTOR_EMAIL=contact@votredomaine.fr

# API formulaires + métrique « nombre d'étudiants » (optionnel en dev : laisser vide pour proxifier /api vers localhost:3001)
# VITE_FORMS_API_URL=https://api.votredomaine.fr
FORMS_API_PORT=3001
FORMS_SQLITE_PATH=data/sporformation-forms.db
# Clé pour PATCH interne /api/internal/metrics/nombre-etudiants (sync depuis votre autre site / BD)
# FORMS_API_SECRET=changez-moi

# Portail visiteurs (comptes hors Supabase Auth / auth.users) — sessions cookie HttpOnly
# À séparer du Cloud staff ; défini uniquement côté serveur.
# PORTAL_SESSION_SECRET=long-secret-aleatoire-minimum-32-caracteres
# Alias accepté : PORTAL_SECRET (= même usage que PORTAL_SESSION_SECRET)
# PORTAL_OTP_PEPPER=secret-optionnel-pour-hash-du-code-e-mail
# PORTAL_COOKIE_SECURE=1

# Supabase — nombre d’apprentis affiché sur l’accueil ([data-live-metric="students"])
#
# L’API Node lit aussi VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY si SUPABASE_URL /
# SUPABASE_ANON_KEY ne sont pas définis (un seul .env.local peut tout contenir).
#
# Console admin : par défaut la table est `admins` (créée par database/supabase-admin-cms.sql).
# Pour utiliser « administrateurs » à la place : créez-la avec database/supabase-administrateurs.sql
# puis définissez :
# SUPABASE_ADMINS_TABLE=administrateurs
# SUPABASE_ADMINS_COL_USER_ID=user_id
# SUPABASE_ADMINS_COL_EMAIL=email
# SUPABASE_ADMINS_COL_ROLE=role
#
# Créez la fonction RPC avec database/supabase-metric-apprentis.sql puis renseignez UNE des paires ci‑dessous :
#
# Convention Vite :
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=votre_cle_anon
#
# Convention Next.js (reconnue aussi par ce projet, voir vite.config envPrefix) :
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon
#
# Ne mettez JAMAIS SUPABASE_SERVICE_ROLE_KEY dans le navigateur — réservé au serveur uniquement.
#
# count_formulaires = COUNT(*) via RPC count_formulaires_etudiants (défaut)
# indicator = valeur dans indicateurs_site (cle nombre_etudiants_actifs), nécessite une policy SELECT anon
# VITE_SUPABASE_METRIC=count_formulaires
# Nom RPC personnalisé si vous l’avez renommé :
# VITE_SUPABASE_RPC_COUNT=count_formulaires_etudiants
