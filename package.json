{
  "name": "spor-formation",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Site vitrine et de candidature du CFA SporFormation",
  "scripts": {
    "dev": "concurrently -n api,vite -c blue,green \"npm run server\" \"npm run dev:vite\"",
    "dev:vite": "node ./node_modules/vite/bin/vite.js",
    "server": "node server/index.js",
    "dev:full": "npm run dev",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview --host"
  },
  "dependencies": {
    "@supabase/auth-js": "2.105.4",
    "@supabase/functions-js": "2.105.4",
    "@supabase/postgrest-js": "2.105.4",
    "@supabase/realtime-js": "2.105.4",
    "@supabase/storage-js": "2.105.4",
    "@supabase/supabase-js": "2.105.4",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "sass": "^1.78.0",
    "vite": "^5.4.0"
  }
}
